    {
      "parameters": {
        "jsCode": "function chunkTranscript(input) {\n  const sermonId = input.id ?? null;\n  const title = input.title ?? '';\n  const speaker = input.speaker ?? 'John Does';\n  const date = '1/12/2025';\n  const transcript = (input.transcript ?? '').trim();\n\n  const MAX_CHARS_PER_CHUNK = 12000;\n  const MIN_CHARS_PER_CHUNK = 4000;\n\n  if (!transcript) {\n    throw new Error('Transcript is empty.');\n  }\n\n  const cleanText = transcript\n    .replace(/\\r\\n/g, '\\n')\n    .replace(/\\t/g, ' ')\n    .replace(/[ ]{2,}/g, ' ')\n    .replace(/\\n{3,}/g, '\\n\\n')\n    .trim();\n\n  const paragraphs = cleanText\n    .split(/\\n\\s*\\n/)\n    .map(p => p.trim())\n    .filter(Boolean);\n\n  const chunks = [];\n  let currentChunk = '';\n\n  for (const paragraph of paragraphs) {\n    if ((currentChunk + '\\n\\n' + paragraph).trim().length <= MAX_CHARS_PER_CHUNK) {\n      currentChunk = currentChunk\n        ? `${currentChunk}\\n\\n${paragraph}`\n        : paragraph;\n      continue;\n    }\n\n    if (currentChunk.length >= MIN_CHARS_PER_CHUNK) {\n      chunks.push(currentChunk.trim());\n      currentChunk = paragraph;\n      continue;\n    }\n\n    const sentences = paragraph.match(/[^.!?]+[.!?]+|[^.!?]+$/g) || [paragraph];\n\n    for (const sentence of sentences) {\n      if ((currentChunk + ' ' + sentence).trim().length <= MAX_CHARS_PER_CHUNK) {\n        currentChunk = currentChunk\n          ? `${currentChunk} ${sentence.trim()}`\n          : sentence.trim();\n      } else {\n        if (currentChunk.trim()) {\n          chunks.push(currentChunk.trim());\n        }\n        currentChunk = sentence.trim();\n      }\n    }\n  }\n\n  if (currentChunk.trim()) {\n    chunks.push(currentChunk.trim());\n  }\n\n  return {\n    sermonId,\n    title,\n    speaker,\n    date,\n    chunkCount: chunks.length,\n    chunks: chunks.map((chunkText, index) => ({\n      sermonId,\n      title,\n      speaker,\n      date,\n      chunkIndex: index + 1,\n      chunkText\n    }))\n  };\n}\n\nconst input = $input.first().json;\nconst result = chunkTranscript(input);\n\nreturn [\n  {\n    json: result\n  }\n];"
      },
