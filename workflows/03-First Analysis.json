        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  model: \"qwen2.5-7b-instruct-1m/v1/chat/completions\",\n  temperature: 0.2,\n  messages: [\n    {\n      role: \"system\",\n      content: \"You analyze sermon transcript excerpts. Be faithful to the text. Do not invent missing content.Return raw JSON only. Do not wrap the JSON in markdown. Do not use ```json fences. Use double quotes for all keys and all string values. Never use single quotes in JSON. Do not include trailing commas.\"\n    },\n    {\n      role: \"user\",\n      content:\n        \"Analyze this sermon transcript chunk and return valid JSON with these fields: chunk_summary, main_ideas, scripture_references, themes, applications, doctrinal_observations, notable_quotes, uncertainties.\\n\\n\" +\n        \"Sermon title: \" + ($json.title ?? \"\") + \"\\n\" +\n        \"Speaker: \" + ($json.speaker ?? \"\") + \"\\n\" +\n        \"Date: \" + ($json.date ?? \"\") + \"\\n\" +\n        \"Chunk index: \" + ($json.chunkIndex ?? \"\") + \"\\n\\n\" +\n        \"Transcript chunk:\\n\" + ($json.chunkText ?? \"\")\n    }\n  ]\n}) }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        320,
        -304
      ],
      "id": "f1e4942d-ca8e-4055-91bb-242c80fb3a50",
      "name": "HTTP Request",
      "notes": "Return raw JSON only.\nDo not wrap the JSON in markdown.\nDo not use ```json fences."
    },
    {
      "parameters": {
        "jsCode": "function parseChunkResponse(input) {\n  const content = input?.choices?.[0]?.message?.content ?? '';\n\n  let cleaned = content.trim();\n\n  // Remove markdown fences\n  cleaned = cleaned\n    .replace(/^```json\\s*/i, '')\n    .replace(/^```\\s*/i, '')\n    .replace(/\\s*```$/i, '')\n    .trim();\n\n  // Try to isolate JSON object\n  const firstBrace = cleaned.indexOf('{');\n  const lastBrace = cleaned.lastIndexOf('}');\n\n  let jsonText = cleaned;\n  if (firstBrace !== -1 && lastBrace !== -1 && lastBrace > firstBrace) {\n    jsonText = cleaned.slice(firstBrace, lastBrace + 1);\n  }\n\n  let parsed = null;\n  let parseError = null;\n\n  try {\n    parsed = JSON.parse(jsonText);\n  } catch (err) {\n    parseError = err.message;\n  }\n\n  return {\n    sermonId: input.sermonId ?? null,\n    chunkIndex: input.chunkIndex ?? null,\n    parsed,\n    parseOk: parsed !== null,\n    parseError,\n    rawContent: content,\n    extractedText: jsonText\n  };\n}\n\nconst input = $input.first().json;\nconst result = parseChunkResponse(input);\n\nreturn [{ json: result }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        112,
        -80
      ],
      "id": "bc4943f4-a6e2-42e8-94ca-2a9057996d0c",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "function aggregateChunkAnalyses(items) {\n  const validItems = items\n    .map(item => item.json)\n    .filter(item => item.parseOk && item.parsed);\n\n  if (!validItems.length) {\n    throw new Error('No valid parsed chunk analyses found.');\n  }\n\n  const first = validItems[0];\n\n  return {\n    sermonId: first.sermonId ?? null,\n    chunkCount: validItems.length,\n    chunkAnalyses: validItems\n      .map(item => ({\n        chunkIndex: item.chunkIndex,\n        ...item.parsed\n      }))\n      .sort((a, b) => (a.chunkIndex ?? 0) - (b.chunkIndex ?? 0))\n  };\n}\n\nconst items = $input.all();\nconst result = aggregateChunkAnalyses(items);\n\nreturn [\n  {\n    json: result\n  }\n];;"
      },
